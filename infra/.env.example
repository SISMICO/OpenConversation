# Copy this file to .env and replace the placeholder values before running docker compose.
#
# Usage:
#   cp .env.example .env
#   docker compose -f infra/docker-compose.yml up

# PostgreSQL credentials (also used by the backend service)
POSTGRES_USER=conversation
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=conversation

# Audio storage bind-mount ownership (Linux/macOS).
# These IDs must match the user/group configured for the backend service in
# infra/docker-compose.yml. Run `infra/setup-audio-volume.sh` before the first
# `docker compose up` to create ./audios with the correct ownership.
# Defaults to 1000:1000.
AUDIO_STORAGE_UID=1000
AUDIO_STORAGE_GID=1000
